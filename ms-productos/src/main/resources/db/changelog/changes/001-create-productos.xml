    <changeSet id="001" author="bruno">
        <createTable tableName="productos">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="nombre" type="VARCHAR(150)">
                <constraints nullable="false"/>
            </column>
            <column name="tipo" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="textil_requerido" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="precio_base" type="DOUBLE">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

