<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="001" author="branco">
        <createTable tableName="pagos">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="pedido_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="metodo_pago" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="monto_base" type="DOUBLE">
                <constraints nullable="false"/>
            </column>
            <column name="porcentaje_descuento" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="monto_descuento" type="DOUBLE">
                <constraints nullable="false"/>
            </column>
            <column name="monto_neto" type="DOUBLE">
                <constraints nullable="false"/>
            </column>
            <column name="iva" type="DOUBLE">
                <constraints nullable="false"/>
            </column>
            <column name="monto_total" type="DOUBLE">
                <constraints nullable="false"/>
            </column>
            <column name="estado" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="fecha_pago" type="DATE">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
