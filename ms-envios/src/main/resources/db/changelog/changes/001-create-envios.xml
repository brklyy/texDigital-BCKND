<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="001" author="tomas">
        <createTable tableName="envios">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="pedido_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="direccion_entrega" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
            <column name="transportista" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="codigo_seguimiento" type="VARCHAR(20)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="estado" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="fecha_creacion" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="fecha_estimada_entrega" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="fecha_entrega_real" type="DATE"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
